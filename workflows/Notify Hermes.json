                "name": "webhook_secret",
                "type": "string",
                "value": "={{ $json.webhook_secret }}"
              },
              {
                "id": "url-field",
                "name": "webhook_url",
                "type": "string",
                "value": "={{ $json.webhook_url }}"
              }
            ]
          }
        }
      },
      {
        "id": "0958b33e-8b46-4a47-8c88-953b7d29eef7",
        "name": "Compute HMAC",
        "type": "n8n-nodes-base.crypto",
        "typeVersion": 1,
        "position": [
          448,
          0
        ],
        "parameters": {
          "action": "hmac",
          "type": "SHA256",
          "value": "={{ $json.body }}",
          "secret": "={{ $json.webhook_secret }}",
          "dataPropertyName": "hmac",
          "encoding": "hex"
        }
      },
      {
        "id": "a1bb60b2-f183-49d6-a05c-9f97dfed6e5c",
        "name": "Build Signature",
        "type": "n8n-nodes-base.set",
        "typeVersion": 3.4,
        "position": [
          672,
          0
        ],
        "parameters": {
          "mode": "manual",
          "includeOtherFields": true,
          "assignments": {
            "assignments": [
              {
                "id": "sig-field",
                "name": "signature",
                "type": "string",
                "value": "={{ \"sha256=\" + $json.hmac }}"
              }
            ]
          }
        }
      },
      {
        "id": "067434a8-a5ec-4c14-9c65-d8e3cdc1dac7",
        "name": "Send to Hermes",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.2,
        "position": [
          896,
          0
        ],
        "parameters": {
          "method": "POST",
          "url": "={{ $json.webhook_url || \"http://192.168.50.11:8644/webhooks/n8n-complete\" }}",
          "sendHeaders": true,
          "headerParameters": {
            "parameters": [
              {
                "name": "X-Hub-Signature-256",
                "value": "={{ $json.signature }}"
              }
            ]
          },
          "sendBody": true,
          "contentType": "raw",
          "rawContentType": "application/json",
          "body": "={{ $json.body }}"
        }
      }
