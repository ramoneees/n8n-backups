        }
      },
      {
        "id": "cd8a7caa-b245-4ac9-aea9-759d3fed9e5d",
        "name": "Build Body",
        "type": "n8n-nodes-base.set",
        "typeVersion": 3.4,
        "position": [
          224,
          0
        ],
        "parameters": {
          "mode": "manual",
          "includeOtherFields": false,
          "assignments": {
            "assignments": [
              {
