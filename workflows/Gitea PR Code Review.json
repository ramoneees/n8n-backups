                "name": "depth",
                "type": "string",
                "value": "={{ ($json.body.pull_request.labels || []).some(l => l.name === 'deep-review') ? 'deep' : 'quick' }}"
              }
            ]
          },
          "options": {}
        },
        "id": "ce55572b-ae15-4d7c-9f72-59f9fbdfbb04",
        "name": "Extract PR Params",
        "type": "n8n-nodes-base.set",
        "typeVersion": 3.4,
        "position": [
          224,
          0
        ]
      },
      {
        "parameters": {
          "url": "={{ 'http://gitea-gitea-web.apps.svc.cluster.local:3000/api/v1/repos/' + $('Extract PR Params').item.json.repo + '/pulls/' + $('Extract PR Params').item.json.pr_number + '.diff' }}",
          "authentication": "genericCredentialType",
          "genericAuthType": "httpHeaderAuth",
          "options": {
            "response": {
              "response": {
                "responseFormat": "text"
              }
            }
          }
        },
        "id": "d91746f6-0d36-421d-b9b1-960db31d7e94",
        "name": "Fetch PR Diff",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.4,
        "position": [
          448,
          0
        ],
        "credentials": {
          "httpHeaderAuth": {
            "id": "zPLpGufpzzOF9CLq",
            "name": "Gitea API Token"
          }
        }
      },
      {
        "parameters": {
          "jsCode": "const params = $('Extract PR Params').first().json;\nconst rawDiff = $input.first().json.data || '';\nconst depth = params.depth;\nconst maxChars = depth === 'deep' ? 32000 : 16000;\nconst diff = rawDiff.length > maxChars ? rawDiff.substring(0, maxChars) + '\\n\\n... [diff truncated]' : rawDiff;\nlet result = { review_text: '', model_used: 'unknown' };\ntry {\n  const resp = await fetch('http://openclaude.olympus.svc.cluster.local:8080/review', {\n    method: 'POST',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify({ diff, repo_url: 'http://gitea-gitea-web.apps.svc.cluster.local:3000/' + params.repo, pr_number: params.pr_number, branch: '', depth, commit_sha: params.commit_sha, prompt_type: 'code-review' }),\n    signal: AbortSignal.timeout(depth === 'deep' ? 310000 : 130000)\n  });\n  result = await resp.json();\n} catch (err) {\n  result.review_text = 'Review unavailable: ' + err.message;\n}\nreturn [{ json: { ...params, review_text: result.review_text || result.error || 'No review generated', model_used: result.model_used || 'unknown' } }];"
        },
        "id": "1b957542-a4de-49d4-ab92-4ab3e3ca3efa",
        "name": "Call OpenClaude Review",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          672,
          0
        ]
      },
      {
        "parameters": {
          "method": "POST",
          "url": "={{ 'http://gitea-gitea-web.apps.svc.cluster.local:3000/api/v1/repos/' + $('Extract PR Params').item.json.repo + '/issues/' + $('Extract PR Params').item.json.pr_number + '/comments' }}",
          "authentication": "genericCredentialType",
          "genericAuthType": "httpHeaderAuth",
          "sendBody": true,
          "specifyBody": "json",
          "jsonBody": "={{ { body: '[AI Review - ' + $('Call OpenClaude Review').item.json.depth.toUpperCase() + '] (model: ' + $('Call OpenClaude Review').item.json.model_used + ' | commit: ' + $('Call OpenClaude Review').item.json.commit_sha.substring(0, 7) + ')\\n\\n' + $('Call OpenClaude Review').item.json.review_text } }}",
          "options": {}
        },
        "id": "4bd70427-02a4-439b-9f87-ea70ab6b6666",
        "name": "Post Gitea PR Comment",
        "type": "n8n-nodes-base.httpRequest",
