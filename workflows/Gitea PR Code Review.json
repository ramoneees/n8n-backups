      {
        "parameters": {
          "assignments": {
            "assignments": [
              {
                "id": "message",
                "name": "message",
                "type": "string",
                "value": "={{ '✅ Code review — PR #' + $('Call OpenClaude Review').item.json.pr_number + ' in ' + $('Call OpenClaude Review').item.json.repo + ' [' + $('Call OpenClaude Review').item.json.depth + ' via ' + $('Call OpenClaude Review').item.json.model_used + ']' }}"
              }
            ]
          },
          "options": {}
        },
        "id": "929ceacd-dfae-4131-81b0-a29181d73544",
