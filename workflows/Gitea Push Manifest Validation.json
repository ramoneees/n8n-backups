        "name": "Push Webhook",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 2.1,
        "position": [
          0,
          96
        ],
        "parameters": {
          "httpMethod": "POST",
          "path": "gitea-push-validate",
          "authentication": "none",
          "responseMode": "onReceived"
        },
        "webhookId": "83c34cca-ed12-43ef-912e-1d1ad5639ed6"
      },
      {
        "id": "c4349965-ffd6-43d8-bfd3-fdf95238be01",
        "name": "Filter YAML Changes",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          224,
          96
        ],
        "parameters": {
          "language": "javaScript",
          "jsCode": "const body = $input.first().json.body;\nconst sha = body.after || '';\nconst repo = body.repository?.full_name || '';\nconst changedFiles = [];\nfor (const commit of (body.commits || [])) {\n  for (const f of [...(commit.added || []), ...(commit.modified || [])]) {\n    if ((f.endsWith('.yaml') || f.endsWith('.yml')) && /^(olympus|apps|infrastructure|databases|monitoring)\\//.test(f)) {\n      if (!changedFiles.includes(f)) changedFiles.push(f);\n    }\n  }\n}\nif (changedFiles.length === 0) {\n  return [{ json: { skip: true, sha, repo } }];\n}\nreturn [{ json: { skip: false, sha, repo, yaml_files: changedFiles } }];"
        }
      },
      {
        "id": "b3471bd7-5c6c-4d4d-82ad-c37effeee0a4",
        "name": "Skip if No YAML",
        "type": "n8n-nodes-base.if",
        "typeVersion": 2,
        "position": [
          448,
          96
        ],
        "parameters": {
          "conditions": {
            "conditions": [
              {
                "leftValue": "={{ $json.skip }}",
                "rightValue": false,
                "operator": {
                  "type": "boolean",
                  "operation": "equals"
                }
              }
            ]
          }
        }
      },
      {
        "id": "9a21d7a7-b257-4e83-b62f-a0fcf0fdfb94",
        "name": "Set YAML File List",
        "type": "n8n-nodes-base.set",
        "typeVersion": 3.4,
        "position": [
          672,
          0
        ],
        "parameters": {
          "mode": "manual",
          "assignments": {
            "assignments": [
              {
                "id": "sha",
                "name": "sha",
                "type": "string",
                "value": "={{ $json.sha }}"
              },
              {
                "id": "repo",
                "name": "repo",
                "type": "string",
                "value": "={{ $json.repo }}"
              },
              {
                "id": "yaml_files",
                "name": "yaml_files",
                "type": "string",
                "value": "={{ JSON.stringify($json.yaml_files) }}"
              }
            ]
          }
        }
      },
      {
        "id": "5a814136-0675-45b8-960c-93b9af73f8c8",
        "name": "Fetch YAML File",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.2,
        "position": [
          896,
