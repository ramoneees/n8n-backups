        ],
        "parameters": {
          "method": "GET",
          "url": "={{ 'http://gitea-gitea-web.apps.svc.cluster.local:3000/api/v1/repos/' + $('Set YAML File List').item.json.repo + '/raw/' + $('Filter YAML Changes').item.json.yaml_files[0] + '?ref=' + $('Set YAML File List').item.json.sha }}",
          "authentication": "genericCredentialType",
          "genericAuthType": "httpHeaderAuth",
          "options": {
            "response": {
              "response": {
                "responseFormat": "text"
              }
            }
          }
        },
        "credentials": {
          "httpHeaderAuth": {
            "id": "gitea-api-token",
            "name": "Gitea API Token"
          }
        }
      },
      {
        "id": "1159ee71-0a0d-4d14-a4a1-6b02cee40931",
        "name": "Call OpenClaude Validate",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.2,
        "position": [
          1120,
          0
        ],
        "parameters": {
          "method": "POST",
