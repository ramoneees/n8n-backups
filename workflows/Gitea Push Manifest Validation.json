          "sendBody": true,
          "contentType": "json",
          "body": "={{ JSON.stringify({ diff: $json.data, depth: 'quick', pr_number: 0, commit_sha: $('Set YAML File List').item.json.sha, repo_url: 'http://gitea-gitea-web.apps.svc.cluster.local:3000/' + $('Set YAML File List').item.json.repo, branch: '', prompt_type: 'manifest-validation' }) }}",
          "options": {
